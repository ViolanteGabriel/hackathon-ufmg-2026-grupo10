# =============================================================================
# EanterOS — Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores necessarios:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Groq API (OBRIGATORIA para o pipeline completo — GRATUITA)
# Crie sua conta e obtenha a chave em: https://console.groq.com
# Sem esta chave, os Estagios 1, 4 e 5 do pipeline nao funcionarao.
# O classificador RN1 (Estagio 3) e o RAG por keyword continuam funcionando.
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# Embeddings locais (sentence-transformers — sem chave de API necessaria)
# O modelo e baixado automaticamente na primeira execucao (~120MB).
# Alternativas: paraphrase-multilingual-mpnet-base-v2 (melhor qualidade, +pesado)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# -----------------------------------------------------------------------------
# Banco de dados PostgreSQL
# No Docker, use o hostname "db" (nome do servico no docker-compose.yml).
# Para desenvolvimento local, substitua "db" por "localhost".
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=enteros_dev
DATABASE_URL=postgresql+psycopg://enteros:enteros_dev@db:5432/enteros

# -----------------------------------------------------------------------------
# Autenticacao JWT
# Altere JWT_SECRET para um valor secreto em qualquer ambiente nao-demo.
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-only-for-demo
JWT_EXPIRE_MINUTES=480

# -----------------------------------------------------------------------------
# Logging
# Niveis: DEBUG | INFO | WARNING | ERROR
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
